#!/bin/sh
# Installs per-tool dependencies before Claude Code tool calls, using receipt
# files in tmp/claude-web-receipts/ as a fast-path cache so only the first
# call per session pays installation cost.
#
# Only reached in Claude Code web sessions — the hook command in settings.json
# short-circuits on CLAUDE_CODE_REMOTE != true before exec'ing this script.
set -eu

INPUT=$(cat)
TOOL_NAME=$(printf '%s' "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null || true)

RECEIPTS_DIR="tmp/claude-web-receipts"
mkdir -p "$RECEIPTS_DIR"

install_gems() {
  local lock_hash
  lock_hash=$(sha256sum Gemfile.lock 2>/dev/null | cut -c1-8 || echo "no-lock")
  local receipt="$RECEIPTS_DIR/gems-$lock_hash"

  [ -f "$receipt" ] && return 0

  bundle install
  touch "$receipt"
}

install_hk() {
  local receipt="$RECEIPTS_DIR/hk"

  # Fast path: receipt present and binary reachable
  if [ -f "$receipt" ] && command -v hk > /dev/null 2>&1; then
    return 0
  fi

  if ! command -v hk > /dev/null 2>&1; then
    if command -v brew > /dev/null 2>&1; then
      brew install hk
    else
      curl -fsSL \
        "https://github.com/jdx/hk/releases/download/v1.46.0/hk-x86_64-unknown-linux-gnu.tar.gz" \
        | tar -xz -C /usr/local/bin hk
    fi
  fi

  touch "$receipt"
}

case "$TOOL_NAME" in
  Edit|Write)
    install_gems
    install_hk
    ;;
esac
