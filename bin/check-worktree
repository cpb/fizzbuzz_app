#!/usr/bin/env bash
# Enforces worktree-first development: blocks all Claude Code tool use when
# running on the main branch. Called by .claude/settings.json PreToolUse hook.

branch=$(git branch --show-current 2>/dev/null)

if [ -z "$branch" ]; then
  echo "ERROR: Could not determine current git branch (detached HEAD or not a git repo)."
  echo "Please check out a branch before starting Claude Code."
  exit 1
fi

if [ "$branch" = "main" ]; then
  echo "BLOCKED: Claude Code cannot use tools on the 'main' branch."
  echo ""
  echo "Each feature or fix requires its own worktree. Create one:"
  echo ""
  echo "  bin/worktree add <branch-name>"
  echo "  eval \"\$(bin/worktree cd <branch-name>)\""
  echo "  claude"
  echo ""
  echo "To see existing worktrees:"
  echo "  bin/worktree list"
  exit 1
fi

exit 0
