#!/usr/bin/env ruby
# frozen_string_literal: true

require "open3"
require "fileutils"
require "shellwords"
require "json"
require "set"

BASE_PORT = 3001
SERVER_LOG = "log/dev_server.log"
SERVER_PID = "tmp/pids/dev_server.pid"

def git_root
  @git_root ||= `git rev-parse --show-toplevel`.strip
end

def main_worktree_path
  @main_worktree_path ||= File.expand_path("..", `git rev-parse --git-common-dir`.strip)
end

def slugify(text)
  text.downcase.strip.gsub(/[^a-z0-9]+/, "-").gsub(/^-+|-+$/, "")
end

def gh_json(command)
  out, status = Open3.capture2("gh #{command}")
  return nil unless status.success?
  JSON.parse(out)
rescue => e
  warn "Error fetching GH info: #{e.message}"
  nil
end

def check_tmux
  abort "ERROR: not inside tmux — run this from inside a tmux session" unless ENV["TMUX"]
end

def tmux_window_target(wt_path, recorded_window)
  # Look for window by name first (authoritative)
  if recorded_window
    out, _ = Open3.capture2("tmux list-windows -a -F '\#{session_name}:\#{window_index} \#{window_name}'")
    target = out.lines.find { |l| l.split[1] == recorded_window }&.split&.first
    return target if target
  end

  # Fallback to pane path (more strict)
  wt_path = File.realdirpath(wt_path) rescue wt_path
  out, _ = Open3.capture2("tmux list-panes -a -F '\#{session_name}:\#{window_index} \#{pane_current_path}'")
  
  # Current target to avoid hijacking unless it's an exact match
  current_target = `tmux display-message -p "\#{session_name}:\#{window_index}"`.strip rescue nil

  target = out.lines.find do |l|
    parts = l.split
    next false if parts.size < 2
    pane_path = File.realdirpath(parts[1]) rescue parts[1]
    
    # Exact match or subpath match (ensure it's a real subpath with trailing slash check)
    match = (pane_path == wt_path || pane_path.start_with?(File.join(wt_path, "")))
    
    # Avoid hijacking current window if it's not an exact match and we have other options
    # But if it matches the path, it's likely the right window even if name changed.
    match
  end&.split&.first

  target
end

# Returns [{path:, branch:}, ...] for all worktrees
def worktrees
  out, = Open3.capture2("git worktree list --porcelain")
  entries = []
  current = {}
  out.each_line do |line|
    line.chomp!
    if line.start_with?("worktree ")
      current = { path: line.sub("worktree ", "") }
    elsif line.start_with?("branch ")
      current[:branch] = line.sub("branch refs/heads/", "")
    elsif line.empty? && current[:path]
      entries << current
      current = {}
    end
  end
  entries << current if current[:path]
  entries
end

def find_worktree(name)
  worktrees.find do |wt|
    File.basename(wt[:path]) == name || wt[:branch] == name
  end
end

def env_local_port(path)
  env_file = File.join(path, ".env.local")
  return nil unless File.exist?(env_file)
  File.read(env_file).match(/^PORT=(\d+)/)&.captures&.first&.to_i
end

def load_session
  return nil unless File.exist?(".worktree-session.json")
  JSON.parse(File.read(".worktree-session.json"))
rescue => e
  warn "Error loading session: #{e.message}"
  nil
end

def next_free_port
  used = worktrees.filter_map { |wt| env_local_port(wt[:path]) }.to_set
  port = BASE_PORT
  port += 1 while used.include?(port)
  port
end

def server_pid(wt_path)
  pid_file = File.join(wt_path, SERVER_PID)
  return nil unless File.exist?(pid_file)
  pid_file_content = File.read(pid_file).strip
  return nil if pid_file_content.empty?
  pid_file_content.to_i
end

def server_running?(wt_path)
  pid = server_pid(wt_path)
  return false unless pid
  Process.kill(0, pid)
  true
rescue Errno::ESRCH, Errno::EPERM
  false
end

TEST_FIRST_HILL_PROTOCOL = <<~MD
  ---

  ## Test-first hill required

  This issue carries the `test-first` label. **You must not write any
  implementation code until the hill draft PR has been reviewed.**

  Your plan must contain **exactly one step**: invoke `/hill-first` with the
  layers described in the acceptance criteria above. **Do not include
  implementation steps, architecture steps, or any other steps in your plan.**
  The plan ends at `/hill-first` — full stop.

  After `/hill-first` completes, a draft PR will be open with failing tests.
  Implementation planning happens in a separate session after the operator
  reviews and removes the `hill-ready` label (via `/continue-pr`).

  **If your plan includes implementation steps, delete them. The plan is wrong.**
MD

CLOSING_PROTOCOL_NEW_PR = <<~MD
  ---

  ## Closing protocol

  Once all acceptance criteria above are met and the test suite passes:

  1. **Make atomic commits as you go** — commit logical units of work as you complete them rather than one monolithic commit at the end. Each commit should be self-contained and aid review.
  2. **Open the PR automatically** — when work is complete, push the branch and open a non-draft PR without waiting for a human prompt:
     ```sh
     git push -u origin HEAD
     gh pr create --title "<descriptive title>" --body "<summary of changes>"
     ```
     Do not stop and ask permission — completing the work means opening the PR.
MD

CLOSING_PROTOCOL_EXISTING_PR = <<~MD
  ---

  ## Closing protocol

  Once all acceptance criteria above are met and the test suite passes:

  1. **Make atomic commits as you go** — commit logical units of work as you complete them rather than one monolithic commit at the end. Each commit should be self-contained and aid review.
  2. **Push automatically when done** — once complete, push the branch without waiting for a human prompt:
     ```sh
     git push
     ```
     The PR is already open — do not stop and ask permission.
MD

def build_pr_context(type, info, test_first: false)
  number = info["number"]
  title  = info["title"]
  url    = info["url"]
  body   = (info["body"] || "").strip
  labels = (info["labels"] || []).map { |l| l["name"] }

  kind = type == "issue" ? "Issue" : "PR"
  label_str = labels.empty? ? "(none)" : labels.join(", ")

  context = <<~MD
    # #{kind} ##{number} — #{title}

    **URL:** #{url}
    **Labels:** #{label_str}

    #{body}
  MD

  if type == "issue" && test_first
    context += "\n#{TEST_FIRST_HILL_PROTOCOL}"
  elsif type == "issue"
    context += "\n#{CLOSING_PROTOCOL_NEW_PR}"
  elsif type == "pr"
    context += "\n#{CLOSING_PROTOCOL_EXISTING_PR}"
  end

  context
end

# ── subcommands ────────────────────────────────────────────────────────────────

def cmd_prepare(args)
  check_tmux
  id = args.shift
  abort "Usage: bin/worktree prepare <id> [--pr|--issue] [--test-first]" unless id
  
  is_pr = args.delete("--pr")
  is_issue = args.delete("--issue")
  test_first_arg = args.delete("--test-first")
  
  type = is_pr ? "pr" : (is_issue ? "issue" : nil)
  
  info = nil
  if type == "pr" || type.nil?
    info = gh_json("pr view #{id} --json number,title,body,url,labels,state,headRefName")
    type = "pr" if info
  end
  
  if info.nil? && (type == "issue" || type.nil?)
    info = gh_json("issue view #{id} --json number,title,body,url,labels,state")
    type = "issue" if info
  end
  
  abort "Could not find Issue/PR #{id}" unless info
  
  number = info["number"]
  title = info["title"]
  slug = slugify(title)
  
  labels = info["labels"] || []
  hill_ready = labels.any? { |l| l["name"] == "hill-ready" }
  test_first_label = labels.any? { |l| l["name"] == "test-first" }
  
  test_first = test_first_arg || test_first_label
  
  branch = type == "pr" ? info["headRefName"] : "issue-#{number}/#{slug[0..49]}"
  prefix = type == "pr" ? "x" : "o"
  
  rc_slug = slug[0..29]
  remote_control = "#{prefix}-#{number}-#{rc_slug}"
  tmux_window = "#{type}-#{number}"
  
  # Ensure worktree exists
  wt = find_worktree(branch)
  if wt
    wt_path = wt[:path]
  else
    # Replace slashes in branch name for the directory name to keep it flat
    safe_branch = branch.gsub("/", "_")
    wt_path = File.expand_path("../../fizzbuzz_#{safe_branch}", main_worktree_path)
    cmd_add([branch, wt_path])
  end

  # Resolve/Create tmux window
  target = tmux_window_target(wt_path, tmux_window)
  unless target
    system("tmux new-window -n #{tmux_window.shellescape} -c #{wt_path.shellescape}")
    target = tmux_window
  end
  
  session = {
    remote_control: remote_control,
    tmux_window: tmux_window,
    tmux_target: target,
    worktree_path: wt_path,
    type: type,
    number: number,
    title: title,
    headRefName: branch,
    url: info["url"],
    test_first: test_first,
    hill_ready: hill_ready
  }
  File.write(File.join(wt_path, ".worktree-session.json"), JSON.pretty_generate(session))
  File.write(File.join(wt_path, "pr_context.md"), build_pr_context(type, info, test_first: test_first))

  # Output JSON for LLM consumption
  puts JSON.pretty_generate(session.merge(info: info))
end

def cmd_harness(args)
  check_tmux
  id = args.shift
  use_gemini = args.include?("--gemini")

  if id
    # Precise branch-name prefix match, then session JSON scan by number field.
    # Never fall back to CWD — fail loudly if id is given but not found.
    wts = worktrees
    wt = wts.find { |w| w[:branch] && (w[:branch] =~ /^(?:refs\/heads\/)?(?:issue|pr)-#{Regexp.escape(id)}(?:\/|$)/ || w[:branch] == id) }
    unless wt
      wt = wts.find do |w|
        sf = File.join(w[:path], ".worktree-session.json")
        next false unless File.exist?(sf)
        JSON.parse(File.read(sf))["number"].to_s == id.to_s
      rescue JSON::ParserError
        false
      end
    end
    abort "Could not find worktree or session file for '#{id}'" unless wt
    session_file = File.join(wt[:path], ".worktree-session.json")
    abort "Could not find .worktree-session.json for '#{id}'" unless File.exist?(session_file)
    session = JSON.parse(File.read(session_file))
  else
    session = load_session
    id = session["number"] if session
  end

  abort "Usage: bin/worktree harness [id]" unless session
  
  wt_path = session["worktree_path"]
  tmux_target = session["tmux_target"] || session["tmux_window"]
  remote_control = session["remote_control"]
  type = session["type"]
  
  # Final verification of target
  actual_target = tmux_window_target(wt_path, session["tmux_window"])
  target = actual_target || tmux_target

  # Ensure the window exists
  unless target && system("tmux has-session -t #{target.shellescape} 2>/dev/null")
    puts "→ Creating new tmux window '#{tmux_target}'..."
    system("tmux new-window -n #{tmux_target.shellescape} -c #{wt_path.shellescape}")
    target = tmux_target
  end
  
  if use_gemini
    cmd = "gemini --skip-trust"
    cmd += " --approval-mode plan" if type == "issue"
    cmd += " --prompt-interactive \"$(< pr_context.md)\""
  else
    cmd = "claude --remote-control #{remote_control}"
    cmd += " --permission-mode plan" if type == "issue"
    cmd += " \"$(< pr_context.md)\""
  end
  
  puts "→ Sending command to tmux window '#{target}':"
  puts "  #{cmd}"
  system("tmux send-keys -t #{target.shellescape} #{cmd.shellescape} Enter")
end

def cmd_check_hill(args)
  check_tmux
  number = args.shift
  if !number && (session = load_session)
    number = session["number"]
  end
  abort "Usage: bin/worktree check-hill [number]" unless number
  
  puts "→ Waiting for CI checks on PR ##{number}..."
  system("gh pr checks #{number} --watch")
  
  checks, _ = Open3.capture2("gh pr checks #{number}")
  info = gh_json("pr view #{number} --json body")
  
  puts "\n--- CI Check Summary ---"
  puts checks
  puts "\n--- PR Description (Expected Failures) ---"
  puts info["body"] if info
end

def cmd_cleanup(args)
  check_tmux
  id = args.shift
  session = nil
  if File.exist?(".worktree-session.json")
    session = JSON.parse(File.read(".worktree-session.json"))
    id ||= session["number"]
  end
  
  abort "Usage: bin/worktree cleanup <id>" unless id
  
  # Wait for CI if it's a PR
  is_pr = session ? (session["type"] == "pr") : true
  if is_pr
    puts "→ Waiting for CI checks on PR ##{id}..."
    system("gh pr checks #{id} --watch")
    # We continue even if it fails, as gh pr merge will fail if required checks are red,
    # or the user can choose to merge anyway if they have permission.
    out, status = Open3.capture2("gh pr checks #{id}")
    unless status.success?
      puts out
      abort "CI failed on PR ##{id}. Fix failures before cleaning up."
    end
  end
  
  unless session
    info = gh_json("pr view #{id} --json number,title,headRefName") || gh_json("issue view #{id} --json number,title")
    abort "Could not find PR/Issue ##{id}" unless info
    session = { "number" => info["number"], "headRefName" => info["headRefName"], "type" => info["headRefName"] ? "pr" : "issue" }
  end
  
  number = session["number"]
  branch = session["headRefName"]
  wt_path = session["worktree_path"] || (branch && find_worktree(branch)&.fetch(:path))
  
  if session["type"] == "pr"
    puts "→ Merging PR ##{number}..."
    system("gh pr merge #{number} --squash") || abort("Merge failed")
    
    if branch
      puts "→ Deleting remote branch #{branch}..."
      system("git push origin --delete #{branch}") rescue nil
    end

    main_wt = `git rev-parse --git-common-dir`.strip
    main_wt = File.expand_path("..", main_wt)
    puts "→ Updating main in #{main_wt}..."
    system("git -C #{main_wt.shellescape} fetch origin main && git -C #{main_wt.shellescape} merge --ff-only origin/main")
  end
  
  if wt_path
    target = tmux_window_target(wt_path, session["tmux_window"])
    if target
      current_target = `tmux display-message -p "\#{session_name}:\#{window_index}"`.strip rescue ""
      if target == current_target
        puts "→ Scheduling self-destruct of this window..."
        system("(sleep 3 && tmux kill-window -t #{target.shellescape}) &")
      else
        puts "→ Closing tmux window #{target}..."
        system("tmux kill-window -t #{target.shellescape}")
      end
    end
    
    cmd_down([branch || File.basename(wt_path)])
  end
  
  puts "Done."
end

def cmd_add(args)
  parent_branch = nil
  if (idx = args.index("--parent"))
    args.delete_at(idx)
    parent_branch = args.delete_at(idx)
  end

  branch = args.shift
  abort "Usage: bin/worktree add [--parent <branch>] <branch> [path]" unless branch

  wt_path = args.shift || File.expand_path("../../fizzbuzz_#{branch}", main_worktree_path)
  wt_path = File.expand_path(wt_path)

  port = next_free_port

  existing_branches, = Open3.capture2("git branch --list #{branch}")
  remote_branches, = Open3.capture2("git branch -r --list origin/#{branch}")

  git_cmd = if existing_branches.strip.empty? && remote_branches.strip.empty?
    ["git", "worktree", "add", wt_path, "-b", branch]
  elsif !existing_branches.strip.empty?
    ["git", "worktree", "add", wt_path, branch]
  else
    ["git", "worktree", "add", "--track", "-b", branch, wt_path, "origin/#{branch}"]
  end

  puts "→ #{git_cmd.join(" ")}"
  system(*git_cmd) || abort("git worktree add failed")

  env_local = File.join(wt_path, ".env.local")
  File.write(env_local, "PORT=#{port}\n")
  puts "→ Wrote #{env_local} (PORT=#{port})"

  puts "→ Running bin/setup --skip-server in #{wt_path}"
  system("cd #{wt_path.shellescape} && bin/setup --skip-server") ||
    warn("  Warning: bin/setup exited non-zero")

  if parent_branch
    parent_wt = find_worktree(parent_branch) || abort("Parent worktree '#{parent_branch}' not found")
    children_file = File.join(parent_wt[:path], ".worktree-children")
    children = File.exist?(children_file) ? JSON.parse(File.read(children_file)) : []
    children << branch unless children.include?(branch)
    File.write(children_file, JSON.generate(children))
    puts "→ Registered as child of '#{parent_branch}'"
  end

  puts
  puts "Worktree ready:"
  puts "  Path:   #{wt_path}"
  puts "  Port:   #{port}"
  puts "  Server: bin/worktree server #{branch}"
  puts "  Shell:  eval \"$(bin/worktree cd #{branch})\""
end

def cmd_down_children(args)
  parent = args.shift
  abort "Usage: bin/worktree down-children <parent>" unless parent
  parent_wt = find_worktree(parent) || abort("No worktree found for '#{parent}'")
  children_file = File.join(parent_wt[:path], ".worktree-children")
  unless File.exist?(children_file)
    puts "No children recorded for '#{parent}'."
    return
  end
  children = JSON.parse(File.read(children_file))
  children.each do |child_branch|
    if find_worktree(child_branch)
      puts "→ Tearing down child worktree: #{child_branch}"
      cmd_down([child_branch])
    else
      puts "→ Skipping '#{child_branch}' (already removed)"
    end
  end
  File.delete(children_file)
  puts "All children of '#{parent}' removed."
end

def cmd_cd(args)
  name = args.shift
  if !name && (session = load_session)
    name = File.basename(session["worktree_path"])
  end
  abort "Usage: bin/worktree cd [name]" unless name
  wt = find_worktree(name) || abort("No worktree found for '#{name}'")
  # Print a cd command for eval — cannot change parent shell directory directly.
  puts "cd #{wt[:path]}"
end

def cmd_server(args)
  name = args.shift
  if !name && (session = load_session)
    name = File.basename(session["worktree_path"])
  end
  abort "Usage: bin/worktree server [name]" unless name
  wt = find_worktree(name) || abort("No worktree found for '#{name}'")
  wt_path = wt[:path]

  if server_running?(wt_path)
    port = env_local_port(wt_path) || "unknown"
    abort "Server already running for '#{name}' on port #{port} (PID #{server_pid(wt_path)})"
  end

  FileUtils.mkdir_p(File.join(wt_path, "log"))
  FileUtils.mkdir_p(File.join(wt_path, "tmp/pids"))

  log_path = File.join(wt_path, SERVER_LOG)
  pid_file = File.join(wt_path, SERVER_PID)
  port = env_local_port(wt_path) || 3000

  # Spawn detached child — pass PORT explicitly so bin/dev doesn't fall back to 3000
  pid = spawn(
    {"PORT" => port.to_s},
    "bin/dev",
    chdir: wt_path,
    out: [log_path, "a"],
    err: [log_path, "a"],
    pgroup: true
  )
  Process.detach(pid)
  File.write(pid_file, pid.to_s)

  puts "Started server for '#{name}' (PID #{pid})"
  puts "  Port: #{port}"
  puts "  Log:  #{log_path}"
  puts "  Logs: bin/worktree logs #{name}"
end

def cmd_logs(args)
  name = args.shift
  if !name && (session = load_session)
    name = File.basename(session["worktree_path"])
  end
  abort "Usage: bin/worktree logs [name]" unless name
  wt = find_worktree(name) || abort("No worktree found for '#{name}'")
  log_path = File.join(wt[:path], SERVER_LOG)
  abort "No log file at #{log_path}" unless File.exist?(log_path)
  exec "tail", "-f", log_path
end

def cmd_stop(args)
  name = args.shift
  if !name && (session = load_session)
    name = File.basename(session["worktree_path"])
  end
  abort "Usage: bin/worktree stop [name]" unless name
  wt = find_worktree(name) || abort("No worktree found for '#{name}'")
  wt_path = wt[:path]

  pid = server_pid(wt_path)
  if pid && server_running?(wt_path)
    puts "→ Stopping server (PID #{pid})"
    Process.kill("TERM", -Process.getpgid(pid))
    sleep 1
  else
    puts "No running server found for '#{name}'"
  end

  pid_file = File.join(wt_path, SERVER_PID)
  File.delete(pid_file) if File.exist?(pid_file)
  puts "Done."
end

def cmd_down(args)
  name = args.shift
  if !name && (session = load_session)
    name = File.basename(session["worktree_path"])
  end
  abort "Usage: bin/worktree down [name]" unless name
  wt = find_worktree(name) || abort("No worktree found for '#{name}'")
  wt_path = wt[:path]

  if (pid = server_pid(wt_path)) && server_running?(wt_path)
    puts "→ Stopping server (PID #{pid})"
    Process.kill("TERM", -Process.getpgid(pid))
    sleep 1
  end
  pid_file = File.join(wt_path, SERVER_PID)
  File.delete(pid_file) if File.exist?(pid_file)

  # Run from git_root so this works even when CWD is the worktree being removed
  # (git refuses to remove its own CWD even with --force).
  puts "→ git worktree remove #{wt_path}"
  out, err, status = Open3.capture3("git -C #{git_root.shellescape} worktree remove --force #{wt_path.shellescape}")
  unless status.success?
    warn out
    warn err
    abort "git worktree remove failed"
  end

  system("git -C #{git_root.shellescape} worktree prune")
  puts "Worktree '#{name}' removed."
end

def cmd_handoff(args)
  id = args.shift
  
  # 1. Resolve PR number
  unless id
    session_file = ".worktree-session.json"
    if File.exist?(session_file)
      id = JSON.parse(File.read(session_file))["number"]
    else
      id = `gh pr view --json number --jq '.number' 2>/dev/null`.strip
      id = nil if id.empty?
    end
  end

  # 2. Fetch PR info
  info = nil
  if id && !id.empty?
    info = gh_json("pr view #{id} --json number,title,url,body")
  end

  # 3. Git context
  branch = `git branch --show-current`.strip
  base = `git merge-base origin/main HEAD 2>/dev/null || git merge-base main HEAD`.strip
  
  commits = []
  unless base.empty?
    out, _ = Open3.capture2("git log #{base}..HEAD --reverse --oneline")
    out.each_line { |line| commits << line.strip }
  end

  files = []
  unless base.empty?
    out, _ = Open3.capture2("git diff #{base}..HEAD --name-only")
    files = out.lines.map(&:strip).uniq
  end

  # 4. Session info
  session = File.exist?(".worktree-session.json") ? JSON.parse(File.read(".worktree-session.json")) : nil

  result = {
    pr: info,
    branch: branch,
    commits: commits,
    changed_files: files,
    session: session
  }

  puts JSON.pretty_generate(result)
end

def cmd_list(_args)
  wts = worktrees
  puts "%-30s %-20s %-6s %s" % ["BRANCH", "PATH", "PORT", "SERVER"]
  wts.each do |wt|
    branch = wt[:branch] || "(detached)"
    path = wt[:path]
    port = env_local_port(path)&.to_s || "-"
    status = server_running?(path) ? "running (PID #{server_pid(path)})" : "-"
    puts "%-30s %-20s %-6s %s" % [branch, File.basename(path), port, status]
  end
end

# ── dispatch ───────────────────────────────────────────────────────────────────

USAGE = <<~USAGE
  Usage: bin/worktree <subcommand> [args]

  Subcommands:
    prepare <id> [--pr|--issue] [--test-first]
                              Fetch GH info, create worktree, output JSON
    harness [id]              Find/create tmux window and launch Claude
    check-hill [number]       Wait for CI and report status for hill PRs
    cleanup <id>              Wait for CI, merge PR, and tear down worktree/window
    add [--parent <p>] <branch> [path]
                              Create isolated worktree with .env.local + setup;
                              --parent records this worktree as a child of <p>
    down-children <parent>    Tear down all child worktrees recorded under <parent>
    cd [name]                 Print cd command (eval "$(bin/worktree cd [name])")
    server [name]             Start dev server in background
    logs [name]               Tail dev server log
    stop [name]               Stop dev server (keeps worktree intact)
    down [name]               Stop server and remove worktree
    handoff [id]              Gather PR and git context for session handoff
    list                      Show all worktrees with port and server status
USAGE

subcommand = ARGV.shift
case subcommand
when "prepare"    then cmd_prepare(ARGV)
when "harness"    then cmd_harness(ARGV)
when "check-hill" then cmd_check_hill(ARGV)
when "cleanup"    then cmd_cleanup(ARGV)
when "add"        then cmd_add(ARGV)
when "cd"         then cmd_cd(ARGV)
when "server"     then cmd_server(ARGV)
when "logs"       then cmd_logs(ARGV)
when "stop"       then cmd_stop(ARGV)
when "down"           then cmd_down(ARGV)
when "down-children"  then cmd_down_children(ARGV)
when "handoff"        then cmd_handoff(ARGV)
when "list"           then cmd_list(ARGV)
else
  puts USAGE
  exit subcommand.nil? ? 0 : 1
end
