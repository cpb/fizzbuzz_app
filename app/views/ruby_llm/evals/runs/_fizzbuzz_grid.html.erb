<% grid_data = fizzbuzz_grid_data(run) %>
<% cell_size = [60 - (grid_data.size * 2), 24].max %>

<div class="mt-6">
  <h2 class="subtitle">FizzBuzz prediction grid</h2>

  <div style="overflow-x: auto;">
    <table style="border-collapse: separate; border-spacing: 2px;">
      <thead>
        <tr>
          <th style="width: 80px; text-align: right; padding-right: 8px; font-size: 0.75rem; font-weight: 600; color: #666; vertical-align: bottom;"></th>
          <% grid_data.each do |entry| %>
            <th style="width: <%= cell_size %>px; text-align: center; font-size: 0.7rem; font-weight: 600; color: #555; padding-bottom: 4px;">
              <%= entry[:number] %>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% RubyLLM::Evals::RunsHelper::FIZZBUZZ_CATEGORIES.each do |category| %>
          <tr>
            <td style="text-align: right; padding-right: 8px; font-size: 0.75rem; color: #666; white-space: nowrap; vertical-align: middle;">
              <%= category %>
            </td>
            <% grid_data.each do |entry| %>
              <td style="width: <%= cell_size %>px; height: <%= cell_size %>px; <%= fizzbuzz_cell_style(category, entry) %> border-radius: 3px;"
                  title="<%= fizzbuzz_cell_title(category, entry) %>">
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-3" style="display: flex; gap: 16px; font-size: 0.75rem; color: #555;">
    <span><span style="display:inline-block; width:12px; height:12px; background:#282828; border-radius:2px; vertical-align:middle; margin-right:4px;"></span>correct</span>
    <span><span style="display:inline-block; width:12px; height:12px; background:#ff3860; border-radius:2px; vertical-align:middle; margin-right:4px;"></span>expected (wrong)</span>
    <span><span style="display:inline-block; width:12px; height:12px; background:#b3ddf2; border-radius:2px; vertical-align:middle; margin-right:4px;"></span>predicted instead</span>
    <span><span style="display:inline-block; width:12px; height:12px; background:#f0f0f0; border-radius:2px; vertical-align:middle; margin-right:4px;"></span>not tested</span>
  </div>
</div>
