<h1>FizzBuzz</h1>

<%= form_with url: root_path, method: :post do |f| %>
  <%= f.label :starting_integer %>
  <%= f.number_field :starting_integer, value: params[:starting_integer] || 10 %>
  <%= f.submit "Start" %>
<% end %>

<% if params[:tab_token].present? %>
  <%= turbo_stream_from "fizz_buzz_channel:#{params[:tab_token]}" %>
<% end %>
<div id="results">
  <% if params[:starting_integer].present? %>
    <%= render "result", result: FizzBuzzer.call(params[:starting_integer].to_i) %>
  <% end %>
</div>
