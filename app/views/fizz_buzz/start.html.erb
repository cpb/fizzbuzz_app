<h1>FizzBuzz</h1>

<%= form_with url: start_fizz_buzz_path, method: :post do |f| %>
  <%= f.label :starting_integer %>
  <%= f.number_field :starting_integer, value: params[:starting_integer] || 100 %>
  <%= f.submit "Start" %>
<% end %>

<%= turbo_stream_from "fizz_buzz_channel" %>
<div id="results">
  <% if params[:starting_integer].present? %>
    <%= render "result", result: FizzBuzzer.call(params[:starting_integer].to_i) %>
  <% end %>
</div>
