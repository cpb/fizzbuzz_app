<h1>Links</h1>
<% if flash[:notice] %>
  <p><%= flash[:notice] %></p>
<% end %>

<%= turbo_stream_from :links %>

<ul id="links">
  <% @links.each do |link| %>
    <%= turbo_stream_from [link, session.id.to_s] %>
    <%= render partial: "links/link", locals: { link: link } %>
  <% end %>
</ul>

<%= link_to "New Link", new_link_path %>
