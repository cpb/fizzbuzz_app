<div id="evaluation-result" class="evaluation evaluation--<%= evaluation.outcome %>">
  <p><%= evaluation.feedback_text %></p>
  <% if evaluation.outcome == "affirm" %>
    <%= form_with model: workbook_session, url: workbook_session_path(workbook_session), method: :patch do |f| %>
      <%= f.hidden_field :current_step, value: "select_trap" %>
      <%= f.submit "Continue →", class: "btn" %>
    <% end %>
  <% end %>
</div>
