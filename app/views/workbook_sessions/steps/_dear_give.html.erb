<h2>PROACTIVELY ENGAGE</h2>
<p>Are you about to ask for a review, or give a review?</p>

<%= form_with model: workbook_session, url: workbook_session_path(workbook_session), method: :patch,
    data: { controller: "workbook-form" } do |f| %>
  <%= f.hidden_field :current_step, value: "dear_give" %>

  <div class="thought-options">
    <label class="thought-option">
      <%= f.radio_button :review_direction, "ask",
          data: { action: "change->workbook-form#submit" } %>
      <span class="thought-text">I'm <strong>asking</strong> for a review</span>
    </label>
    <label class="thought-option">
      <%= f.radio_button :review_direction, "give",
          data: { action: "change->workbook-form#submit" } %>
      <span class="thought-text">I'm <strong>giving</strong> a review</span>
    </label>
  </div>

  <div class="navigation">
    <%= link_to "Back", workbook_session_path(workbook_session, direction: "back"),
        data: { turbo_method: :patch }, class: "btn btn--secondary" %>
    <%= f.submit "Next", class: "btn" %>
  </div>
<% end %>
