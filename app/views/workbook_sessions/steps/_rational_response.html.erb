<h2>CHALLENGE BIASED THINKING</h2>

<div class="context-box">
  <strong>Your most strongly believed thought:</strong>
  <p><%= workbook_session.primary_thought&.thought %></p>
</div>

<p>7. Write down a rational response to your biased thought:</p>

<p>Guiding Questions:</p>
<ul>
  <li><em>What is a more balanced view of the situation?</em></li>
  <li><em>What would you say if this were your best friend?</em></li>
  <li><em>What was the strongest piece of evidence against your thought?</em></li>
</ul>

<%= form_with model: workbook_session, url: workbook_session_path(workbook_session), method: :patch do |f| %>
  <%= f.hidden_field :current_step, value: "rational_response" %>

  <div class="field">
    <%= f.label :rational_response, "Rational Response:" %>
    <%= f.text_area :rational_response, rows: 4, placeholder: "A more balanced way to think about this situation..." %>
  </div>

  <div class="field">
    <%= f.label :rational_believability, "Believability Rating (0–100):" %>
    <%= f.number_field :rational_believability, in: 0..100, placeholder: "0–100" %>
  </div>

  <div class="navigation">
    <%= link_to "Back", workbook_session_path(workbook_session, direction: "back"),
        data: { turbo_method: :patch }, class: "btn btn--secondary" %>
    <%= f.submit "Next", class: "btn" %>
  </div>
<% end %>
