<div class="workbook-step">
  <h2>Mini Toolkit Summary</h2>
  <p>Congratulations on completing the Code Review Anxiety Workbook!</p>

  <% if workbook_session.situation_description.present? %>
    <div class="context-box">
      <p><strong>Situation:</strong> <%= workbook_session.situation_description %></p>
    </div>
  <% end %>

  <p><strong>Anxiety Progress (SUDS)</strong></p>
  <%
    suds_bars  = [[workbook_session.suds_initial, "Initial"]]
    suds_bars << [workbook_session.suds_post_tipp,           "Post-TIPP"] if workbook_session.suds_post_tipp.present?
    suds_bars << [workbook_session.suds_post_restructuring,  "Final"]     if workbook_session.suds_post_restructuring.present?
    suds_color = ->(s) { s.to_i >= 7 ? "#D4849C" : s.to_i >= 3 ? "#E8855A" : "#7AC4B6" }
    sw = 280; sh = 170; lp = 30; rp = 10; tp = 22; bp = 30
    bah = sh - tp - bp   # bar area height = 118
    bly = tp + bah       # baseline y = 140
    baw = sw - lp - rp   # bar area width = 240
    n   = suds_bars.size
    spc = baw.to_f / (n + 1)
    bw  = n == 1 ? 50 : 40
  %>
  <svg viewBox="0 0 <%= sw %> <%= sh %>" width="100%" style="max-width: 320px; display: block; margin-bottom: 1rem;">
    <line x1="<%= lp %>" y1="<%= tp - 4 %>" x2="<%= lp %>" y2="<%= bly %>" stroke="#2C2C2C" stroke-width="1.5"/>
    <line x1="<%= lp %>" y1="<%= bly %>" x2="<%= sw - rp %>" y2="<%= bly %>" stroke="#2C2C2C" stroke-width="1.5"/>
    <% [0, 5, 10].each do |tick| %>
      <% ty = (bly - tick * bah / 10.0).round %>
      <line x1="<%= lp - 4 %>" y1="<%= ty %>" x2="<%= lp %>" y2="<%= ty %>" stroke="#2C2C2C" stroke-width="1"/>
      <text x="<%= lp - 6 %>" y="<%= ty + 4 %>" text-anchor="end" font-size="9" fill="#2C2C2C" opacity="0.6" font-family="Arial,sans-serif"><%= tick %></text>
    <% end %>
    <% ty5 = (bly - 5 * bah / 10.0).round %>
    <line x1="<%= lp %>" y1="<%= ty5 %>" x2="<%= sw - rp %>" y2="<%= ty5 %>" stroke="#2C2C2C" stroke-width="0.5" opacity="0.15" stroke-dasharray="4,3"/>
    <% suds_bars.each_with_index do |(score, label), i| %>
      <%
        s   = score.to_i
        cx  = (lp + spc * (i + 1)).round
        bh  = [(s * bah / 10.0).round, 2].max
        by  = bly - bh
        sty = [by - 4, 12].max
      %>
      <rect x="<%= cx - bw / 2 %>" y="<%= by %>" width="<%= bw %>" height="<%= bh %>" fill="<%= suds_color.(s) %>"/>
      <text x="<%= cx %>" y="<%= sty %>" text-anchor="middle" font-size="11" font-weight="bold" fill="#2C2C2C" font-family="Arial,sans-serif"><%= s %></text>
      <text x="<%= cx %>" y="<%= bly + 14 %>" text-anchor="middle" font-size="9" fill="#2C2C2C" opacity="0.7" font-family="Courier New,monospace"><%= label %></text>
    <% end %>
  </svg>

  <% if workbook_session.tipp_strategy.present? %>
    <p><strong>TIPP technique used:</strong> <%= workbook_session.tipp_strategy %></p>
  <% end %>

  <% if workbook_session.biased_thoughts.any? %>
    <p><strong>Biased Thoughts:</strong></p>
    <table class="workbook-table thoughts-table">
      <thead>
        <tr>
          <th>Thought</th>
          <th>Pre</th>
          <th>Post</th>
        </tr>
      </thead>
      <tbody>
        <% workbook_session.biased_thoughts.each do |bt| %>
          <tr>
            <td><%= bt.thought %></td>
            <td style="width: 4rem; text-align: center;"><%= bt.pre_believability %></td>
            <td style="width: 4rem; text-align: center;"><%= bt.post_believability %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <p><strong>Primary thought challenged:</strong></p>
  <blockquote><%= workbook_session.primary_thought_text %></blockquote>

  <% if workbook_session.evidence_against.present? %>
    <p><strong>Key evidence against it:</strong></p>
    <p><%= workbook_session.evidence_against %></p>
  <% end %>

  <% if workbook_session.rational_response.present? %>
    <p><strong>Rational Response:</strong></p>
    <p><%= workbook_session.rational_response %>
      <% if workbook_session.rational_believability.present? %>
        <em>(believability: <%= workbook_session.rational_believability %>)</em>
      <% end %>
    </p>
  <% end %>

  <% if workbook_session.dear_plan.present? %>
    <p><strong>DEAR Request Plan:</strong></p>
    <p><%= workbook_session.dear_plan %></p>
  <% end %>

  <% if workbook_session.give_plan.present? %>
    <p><strong>GIVE Review Plan:</strong></p>
    <p><%= workbook_session.give_plan %></p>
  <% end %>

  <%= link_to "Replay", workbook_session_replay_path(workbook_session), class: "btn" %>
</div>
