<h2>CHALLENGE BIASED THINKING</h2>

<div class="context-box">
  <strong>Your most strongly believed thought:</strong>
  <p><%= workbook_session.primary_thought&.thought %></p>
</div>

<p>6. Evaluate the evidence for and against this thought:</p>

<p>Guiding Questions:</p>
<ul>
  <li><em>Am I 100% sure of this? Can I tell the future, or read minds?</em></li>
  <li><em>What is the worst that could happen? Could I handle it?</em></li>
  <li><em>Is there another explanation / way of looking at this situation?</em></li>
  <li><em>Am I placing unrealistic and unattainable standards on myself that I wouldn't expect another person to achieve?</em></li>
  <li><em>Am I overestimating the probability of this?</em></li>
  <li><em>Am I blaming myself for a situation outside of my control?</em></li>
</ul>

<%= form_with model: workbook_session, url: workbook_session_path(workbook_session), method: :patch do |f| %>
  <%= f.hidden_field :current_step, value: "evidence" %>

  <table class="workbook-table evidence-table">
    <thead>
      <tr>
        <th>Evidence FOR<br><small>(The thought is realistic and true)</small></th>
        <th>Evidence AGAINST<br><small>(The thought is unrealistic and false)</small></th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><%= f.text_area :evidence_for, rows: 6, placeholder: "What supports this thought being true?" %></td>
        <td><%= f.text_area :evidence_against, rows: 6, placeholder: "What contradicts this thought?" %></td>
      </tr>
    </tbody>
  </table>
  <p><em>* If there is evidence in the FOR column, check whether it is due to a thinking error!</em></p>

  <div class="navigation">
    <%= link_to "Back", workbook_session_path(workbook_session, direction: "back"),
        data: { turbo_method: :patch }, class: "btn btn--secondary" %>
    <%= f.submit "Next", class: "btn" %>
  </div>
<% end %>
