<div data-replay-step="<%= step %>">
  <% case step %>
  <% when "suds_initial" %>
    <p>Anxiety level: <%= workbook_session.suds_initial %>/10</p>
  <% when "describe_situation" %>
    <% if workbook_session.situation_description.present? %>
      <div data-controller="word-by-word">
        <% workbook_session.situation_description.to_s.split.each do |word| %>
          <span data-word-by-word-target="word"><%= word %></span>
        <% end %>
      </div>
    <% end %>
  <% when "rational_response" %>
    <% if workbook_session.rational_response.present? %>
      <div data-controller="word-by-word">
        <% workbook_session.rational_response.to_s.split.each do |word| %>
          <span data-word-by-word-target="word"><%= word %></span>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p><%= step.humanize %></p>
  <% end %>
</div>
