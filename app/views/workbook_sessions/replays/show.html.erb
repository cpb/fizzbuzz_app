<div data-controller="replay" data-action="click->replay#advance">
  <div id="replay-step">
    <%= render "workbook_sessions/replays/step",
               workbook_session: @workbook_session,
               step: @replay_step %>
  </div>

  <%= form_with url: advance_workbook_session_replay_path(@workbook_session),
                data: { replay_target: "advanceForm" } do |f| %>
    <%= f.hidden_field :replay_step, value: @replay_step, data: { replay_target: "replayStep" } %>
  <% end %>

  <p data-testid="replay-hint">Click to advance the replay</p>
</div>
