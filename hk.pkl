amends "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["rubocop"] {
        glob = "**/*.rb"
        exclude = List("vendor/**")
        check = "PATH=$HOME/.rbenv/shims:$PATH bundle exec rubocop -f github {{ files }}"
        fix = "PATH=$HOME/.rbenv/shims:$PATH bundle exec rubocop -A {{ files }}"
    }
}

local brakem = new Mapping<String, Step> {
    ["brakeman"] {
        check = "PATH=$HOME/.rbenv/shims:$PATH bin/brakeman --no-pager"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["pre-push"] {
        steps = brakem
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
    ["brakeman"] {
        steps = brakem
    }
}
