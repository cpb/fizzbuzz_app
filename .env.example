# Worktree overrides — copy to .env.local (gitignored) and customize.
# Each git worktree should use a unique PORT so dev servers don't conflict.
# Database paths are relative to the worktree root and are naturally isolated.
#
# Shell integration for `bin/worktree cd`:
#   Add to ~/.zshrc or ~/.bashrc:
#     wcd() { eval "$(bin/worktree cd "$1")"; }
#
PORT=3000
PIDFILE=tmp/pids/server.pid
DEVELOPMENT_DATABASE=storage/development.sqlite3
TEST_DATABASE=storage/test.sqlite3
# Required by skills that use the gh CLI (start-pr, continue-pr, finish-pr, qa-pr, qa-pr-app, new-issue)
# GITHUB_TOKEN=
